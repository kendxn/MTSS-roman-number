<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
          "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
          "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
  
  <module name="FileLength">
    <property name="max" value="5"/> 
  </module>

  <module name="TreeWalker">
    <module name="BooleanExpressionComplexity"/>    <!-- max 3 cicli di boolean-->
    <module name="CyclomaticComplexity"/>   
    <module name="MethodLength">                    <!-- lunghezza massima x righe per method chiusure comprese-->
      <property name="max" value="200"/>
    </module>

    <module name="AvoidStarImport"/> 
    <module name="IllegalImport"/> <!-- non usare librerie non standard o vietate-->

    <module name="NeedBraces"/> <!-- usa sempre graffe-->
    <module name="EmptyCatchBlock"/> 
  </module>

</module>